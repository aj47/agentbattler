{
  "name": "agentbattler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:convex": "convex dev",
    "dev:all": "concurrently -n next,convex -c cyan,magenta \"npm:dev\" \"npm:dev:convex\"",
    "build": "next build",
    "start": "wrangler pages dev out",
    "seed": "convex run seed:run",
    "deploy:pages": "wrangler pages deploy out --project-name agentbattler"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "convex": "^1.17.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.84.0"
  }
}
